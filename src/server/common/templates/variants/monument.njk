<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle }} | AI at Defra</title>
  <meta name="robots" content="noindex">
  <link href="{{ getAssetPath('src/client/stylesheets/showcase-fonts.scss') }}" rel="stylesheet">
  <link href="{{ getAssetPath('src/client/stylesheets/monument.scss') }}" rel="stylesheet">
</head>
<body class="mon-body">
  <a href="#main-content" class="mon-skip-link">Skip to main content</a>
  <div class="mon-page">
    <div class="mon-review">
      <div class="mon-review__inner">
        <span class="mon-review__label">Design review</span>
        <a href="/" class="mon-review__link">&larr; All variants</a>
      </div>
    </div>
    <header class="mon-header">
      <div class="mon-header__inner">
        <a href="/monument" class="mon-brand" aria-label="AI at Defra, Department for Environment, Food and Rural Affairs">
          <span class="mon-brand__logo" aria-hidden="true"></span>
          <span class="mon-brand__name">AI at Defra</span>
        </a>
        <nav aria-label="Primary" class="mon-nav">
          <a href="/monument" class="mon-nav__link">Case studies</a>
          <a href="/monument/blog" class="mon-nav__link">Blog</a>
          <a href="/monument/how-we-work" class="mon-nav__link">How we work</a>
          <a href="/monument/strategy" class="mon-nav__link">Strategy</a>
          <a href="/monument/careers" class="mon-nav__link">Careers</a>
        </nav>
      </div>
    </header>

    {% block main %}{% endblock %}

    <footer class="mon-footer">
      <div class="mon-footer__inner">
        <div class="mon-footer__row">
          <span class="mon-footer__logo" role="img" aria-label="Department for Environment, Food and Rural Affairs"></span>
          <nav aria-label="Legal" class="mon-footer__legal">
            <a href="#">Privacy</a>
            <a href="#">Cookies</a>
            <a href="#">Accessibility statement</a>
            <a href="#">Contact</a>
          </nav>
        </div>
        <p class="mon-footer__licence">All content is available under the <a href="#">Open Government Licence v3.0</a>, except where otherwise stated. &copy; Crown copyright 2026. Built in the open. The source for this site is on GitHub.</p>
      </div>
    </footer>
  </div>
  <script type="module" src="{{ getAssetPath('src/client/javascripts/monument.js') }}"></script>
</body>
</html>
